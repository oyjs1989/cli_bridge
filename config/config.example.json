{
  "driver": {
    "mode": "claude",
    "timeout": 180,
    "workspace": "~/.cli-bridge/workspace",

    "claude_path": "claude",
    "claude_model": "claude-opus-4-6",
    "claude_system_prompt": "",
    "claude_yolo": true,
    "max_turns": 40
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "token": "YOUR_TELEGRAM_BOT_TOKEN",
      "allow_from": []
    },
    "discord": {
      "enabled": false,
      "token": "YOUR_DISCORD_BOT_TOKEN",
      "allow_from": []
    },
    "feishu": {
      "enabled": false,
      "app_id": "YOUR_FEISHU_APP_ID",
      "app_secret": "YOUR_FEISHU_APP_SECRET",
      "encrypt_key": "",
      "verification_token": "",
      "allow_from": [],
      "ssl_verify": true
    },
    "dingtalk": {
      "enabled": false,
      "client_id": "",
      "client_secret": "",
      "allow_from": []
    },
    "slack": {
      "enabled": false,
      "bot_token": "",
      "app_token": "",
      "allow_from": [],
      "group_policy": "mention"
    }
  },
  "log_level": "INFO",
  "log_file": ""
}
